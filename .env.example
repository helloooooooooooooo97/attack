# 复制为 .env 后按需修改: cp .env.example .env

COMPOSE_PROJECT_NAME=redblue

# 靶标入口（经 gateway 暴露到宿主机）
DVWA_PORT=8080
JUICE_PORT=3000
INTRANET_PORT=8081

# 蓝队看板
WAZUH_DASHBOARD_PORT=5601
EVEBOX_PORT=5636

# 评分平台（可选 profile: ctfd）
CTFD_PORT=8000

# Wazuh 默认账号（首次登录后请修改）
WAZUH_DASHBOARD_USER=admin
WAZUH_DASHBOARD_PASSWORD=SecretPassword

# 演练用弱口令内网服务（仅限本地靶场）
INTRANET_USER=admin
INTRANET_PASSWORD=admin123

# CTFd
CTFD_ADMIN_USER=admin
CTFD_ADMIN_PASSWORD=ChangeMeNow!
