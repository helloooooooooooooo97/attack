# 红蓝对抗本地规则 — 仅用于授权靶场检测演示

# 场景1：疑似 SQL 注入
alert http any any -> $HOME_NET any (msg:"REDBLUE SQL Injection Attempt"; flow:to_server,established; http.uri; content:"union"; nocase; content:"select"; nocase; classtype:web-application-attack; sid:1000001; rev:1;)
alert http any any -> $HOME_NET any (msg:"REDBLUE SQLi OR 1=1 Pattern"; flow:to_server,established; http.uri; content:"or"; nocase; content:"1=1"; classtype:web-application-attack; sid:1000002; rev:1;)
alert http any any -> $HOME_NET any (msg:"REDBLUE SQLi Quote Probe"; flow:to_server,established; http.uri; content:"'"; classtype:web-application-attack; sid:1000003; rev:1;)

# 场景2：内网弱口令爆破特征（短时间大量 401 由 Wazuh 侧关联；此处抓明显爆破 UA）
alert http any any -> $HOME_NET any (msg:"REDBLUE Brute Force Tool UA"; flow:to_server,established; http.user_agent; content:"hydra"; nocase; classtype:attempted-admin; sid:1000010; rev:1;)
alert http any any -> $HOME_NET any (msg:"REDBLUE Intranet Auth Probe"; flow:to_server,established; http.host; content:"8081"; classtype:web-application-activity; sid:1000011; rev:1;)

# 场景3：异常出站 / 恶意探测标记
alert http any any -> $HOME_NET any (msg:"REDBLUE Suspicious Lab Exfil Marker"; flow:to_server,established; http.uri; content:"/lab-exfil"; nocase; classtype:trojan-activity; sid:1000020; rev:1;)
alert http any any -> $HOME_NET any (msg:"REDBLUE sqlmap User-Agent"; flow:to_server,established; http.user_agent; content:"sqlmap"; nocase; classtype:web-application-attack; sid:1000021; rev:1;)
alert http any any -> $HOME_NET any (msg:"REDBLUE Nikto Scanner"; flow:to_server,established; http.user_agent; content:"Nikto"; nocase; classtype:web-application-attack; sid:1000022; rev:1;)
